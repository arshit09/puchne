{
  "manifest_version": 3,
  "name": "Puchne - Ask Every AI at Once",
  "version": "1.0.0",
  "description": "Send one prompt to ChatGPT, Claude, Gemini, Copilot, DeepSeek & more — all at once. Open source.",
  "author": "Puchne Contributors",

  "permissions": ["storage", "activeTab", "tabs", "scripting", "tabGroups", "declarativeNetRequest", "webNavigation"],

  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://chat.deepseek.com/*",
    "https://www.perplexity.ai/*"
  ],

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "grid_headers",
        "enabled": true,
        "path": "rules/grid_headers.json"
      }
    ]
  },

  "background": {
    "service_worker": "scripts/background.js"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "MacCtrl+Shift+X"
      },
      "description": "Open Puchne popup"
    }
  },

  "options_ui": {
    "page": "pages/options.html",
    "open_in_tab": true
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*",
        "https://www.perplexity.ai/*"
      ],
      "js": ["scripts/constants.js", "scripts/content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*.svg", "icons/*.png", "pages/grid.html", "scripts/cookie-dismiss.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
